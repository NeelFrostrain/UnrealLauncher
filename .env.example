# Environment Configuration for UnrealLauncher
# Copy this file to .env and fill in your actual values

# App version — keep in sync with package.json "version"
VITE_APP_VERSION=0.0.0

# Discord webhook URL for feedback/bug reports
VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Discord server invite link
VITE_DISCORD_INVITE_URL=https://discord.gg/YOUR_INVITE_CODE

# GitHub repository base URL
VITE_GITHUB_REPO_URL=https://github.com/YOUR_USERNAME/YOUR_REPO

# Ko-fi donation link
VITE_KOFI_URL=https://ko-fi.com/YOUR_USERNAME
